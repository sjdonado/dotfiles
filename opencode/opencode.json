{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"model": "openai/gpt-5.6-sol",
	"permission": {
		"bash": {
			"opencode *": "deny",
			"*/opencode *": "deny"
		},
		"skill": {
			"*": "allow",
			"pr-review": "deny"
		}
	},
	"provider": {
		"openai": {
			"models": {
				"gpt-5.6-sol": {
					"options": {
						"reasoningEffort": "high"
					}
				}
			}
		},
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://localhost:11434/v1"
			},
			"models": {
				"gemma4:e4b": {
					"name": "Gemma 4 e4b (local)",
					"tool_call": true,
					"limit": {
						"context": 128000,
						"output": 8192
					}
				}
			}
		}
	},
	"agent": {
		"ollama": {
			"description": "Local Ollama profile without MCP or delegated agents",
			"mode": "primary",
			"model": "ollama/gemma4:e4b",
			"permission": {
				"linear_*": "deny",
				"posthog_*": "deny",
				"task": "deny"
			}
		}
	}
}
