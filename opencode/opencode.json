{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"permission": {
		"external_directory": "allow",
		"bash": {
			"opencode *": "deny",
			"*/opencode *": "deny"
		}
	},
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://localhost:11434/v1"
			},
			"models": {
				"gemma4:e4b": {
					"name": "Gemma 4 e4b (local)",
					"tool_call": true,
					"limit": {
						"context": 128000,
						"output": 8192
					}
				}
			}
		}
	},
	"mcp": {
		"linear": {
			"type": "remote",
			"url": "https://mcp.linear.app/mcp",
			"enabled": true
		},
		"posthog": {
			"type": "remote",
			"url": "https://mcp-eu.posthog.com/mcp",
			"enabled": true,
			"headers": {
				"Authorization": "Bearer {env:MCP_POSTHOG_API_KEY}"
			}
		},
		"grafana": {
			"type": "local",
			"command": ["uvx", "mcp-grafana"],
			"enabled": true,
			"environment": {
				"GRAFANA_URL": "https://autarc.grafana.net",
				"GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:MCP_GRAFANA_SERVICE_ACCOUNT_TOKEN}"
			}
		},
		"sentry": {
			"type": "local",
			"command": ["npx", "@sentry/mcp-server"],
			"enabled": true,
			"environment": {
				"SENTRY_ACCESS_TOKEN": "{env:MCP_SENTRY_ACCESS_TOKEN}"
			}
		},
		"supabase": {
			"type": "remote",
			"url": "https://mcp.supabase.com/mcp?read_only=true",
			"enabled": true
		}
	},
	"agent": {
		"ollama": {
			"description": "Local Ollama profile without MCP or delegated agents",
			"mode": "primary",
			"model": "ollama/gemma4:e4b",
			"permission": {
				"linear_*": "deny",
				"posthog_*": "deny",
				"task": "deny"
			}
		}
	}
}
