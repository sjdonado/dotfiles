[
  {
    "context": "Editor",
    "bindings": {
      "cmd-;": null,
      "cmd-[": null,
      "cmd-]": null,
    },
  },
  {
    "bindings": {
      "cmd-;": "terminal_panel::ToggleFocus",
      "cmd-shift-g": "git_panel::Toggle",
      "cmd-t": ["workspace::SendKeystrokes", "cmd-n"],
      "cmd-ctrl-o": "projects::OpenRecent",
      "ctrl-w ctrl-w": "git::Worktree",
      "ctrl-w ctrl-n": "agent::NewThread",
      "cmd-[": "multi_workspace::ToggleWorkspaceSidebar",
      "cmd-]": "workspace::ToggleRightDock",
    },
  },
]
