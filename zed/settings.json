{
  "close_on_file_delete": false,
  "search": {
    "include_ignored": false
  },
  "project_panel": {
    "diagnostic_badges": true,
    "git_status_indicator": true,
    "default_width": 360.0
  },
  "outline_panel": {
    "default_width": 360.0
  },
  "cli_default_open_behavior": "existing_window",
  "tabs": {
    "git_status": false
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "context_servers": {},
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.5"
      },
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "type": "registry",
      "favorite_models": ["sonnet"],
      "favorite_config_option_values": {
        "model": ["default"],
      },
    },
  },
  "auto_update": false,
  "git_panel": {
    "show_count_badge": true,
    "file_icons": false,
    "tree_view": true,
  },
  "use_system_window_tabs": true,
  "theme": {
    "light": "One Light",
    "dark": "One Dark - Darkened",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "soft_wrap": "editor_width",
  "edit_predictions": {
    "ollama": {
      "max_output_tokens": 128,
      "model": "gemma4:e4b"
    },
    "provider": "copilot",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "agent": {
    "play_sound_when_agent_done": "when_hidden",
    "thinking_display": "always_expanded",
    "default_width": 360.0,
    "show_turn_stats": true,
    "tool_permissions": {
      "default": "confirm",
    },
    "default_model": {
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "default_profile": "write",
    "model_parameters": [],
  },
}
