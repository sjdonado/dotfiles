[user]
  email = sjdonado@icloud.com
  name = Juan Rodriguez Donado

[pull]
  rebase = false

[core]
  editor = vim

[merge]
  conflictstyle = merge

[diff]
  colorMoved = default

[init]
  defaultBranch = main

[credential]
  helper = store

[push]
  autoSetupRemote = true

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[safe]
	directory = /opt/homebrew
	directory = /opt/homebrew/Library/Taps/amberframework/homebrew-micrate
	directory = /opt/homebrew/Library/Taps/oven-sh/homebrew-bun
	directory = /opt/homebrew

[delta]
  features = github-dark
  navigate = true
  file-modified-label = "~"
  file-added-label = "+"
  file-removed-label = "-"
  file-renamed-label = "→"
  line-numbers-left-format = "{nm:>3}│"
  line-numbers-right-format = "{np:>3}│"
  hunk-header-decoration-style = omit
  file-style = bold
  file-decoration-style = ul

[delta "github-dark"]
  syntax-theme = GitHub-Dark
  minus-style = syntax "#3c1618"
  minus-emph-style = syntax "#7a2226"
  plus-style = syntax "#0f2f1a"
  plus-emph-style = syntax "#1f6f3f"
  line-numbers-minus-style = "#f85149"
  line-numbers-plus-style = "#3fb950"
  line-numbers-zero-style = "#484f58"
  hunk-header-style = syntax bold
  hunk-header-line-number-style = "#58a6ff"

[delta "github-light"]
  syntax-theme = GitHub-Light
  minus-style = syntax "#ffebe9"
  minus-emph-style = syntax "#ffc0bd"
  plus-style = syntax "#e6ffec"
  plus-emph-style = syntax "#abf2bc"
  line-numbers-minus-style = "#cf222e"
  line-numbers-plus-style = "#1a7f37"
  line-numbers-zero-style = "#8c959f"
  hunk-header-style = syntax bold
  hunk-header-line-number-style = "#0969da"
