#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") REMOTE_SESSION_PATH [LOCAL_BRANCH]" >&2
  exit 2
}

[[ $# -ge 1 && $# -le 2 ]] || usage

session_path=$1
requested_branch=${2:-}
host=${CODER_HOST:-sjdonado.coder}
dev_root=${DEV_ROOT:-$HOME/Developer}

for command in ssh git wt pi python3 base64; do
  command -v "$command" >/dev/null 2>&1 || {
    echo "Missing required command: $command" >&2
    exit 1
  }
done

encoded_path=$(printf '%s' "$session_path" | base64 | tr -d '\n')
metadata=$(
  ssh "$host" "SESSION_PATH_B64='$encoded_path' python3 -" <<'PY'
import base64
import json
import os
import subprocess

path = base64.b64decode(os.environ["SESSION_PATH_B64"]).decode()
with open(path, encoding="utf-8") as session:
    header = json.loads(session.readline())

cwd = header.get("cwd")
if not cwd or not os.path.isdir(cwd):
    raise SystemExit("Session working directory does not exist")

def git(*args):
    return subprocess.check_output(
        ["git", "-C", cwd, *args], text=True, stderr=subprocess.DEVNULL
    ).strip()

branch = git("branch", "--show-current")
if not branch:
    raise SystemExit("Session worktree is on a detached HEAD")

origin = git("config", "--get", "remote.origin.url")
repo = origin.rstrip("/").rsplit("/", 1)[-1]
if ":" in repo:
    repo = repo.rsplit(":", 1)[-1]
if repo.endswith(".git"):
    repo = repo[:-4]

print(json.dumps({
    "branch": branch,
    "cwd": cwd,
    "dirty": bool(git("status", "--porcelain")),
    "repo": repo,
    "session_id": header.get("id", "session"),
    "sha": git("rev-parse", "HEAD"),
}))
PY
)

read_field() {
  python3 -c 'import json,sys; print(json.load(sys.stdin)[sys.argv[1]])' "$1" <<<"$metadata"
}

remote_branch=$(read_field branch)
remote_cwd=$(read_field cwd)
remote_dirty=$(read_field dirty)
repo_name=$(read_field repo)
session_id=$(read_field session_id)
remote_sha=$(read_field sha)
local_repo="$dev_root/$repo_name"

[[ -d "$local_repo/.git" ]] || {
  echo "Local repository not found: $local_repo" >&2
  exit 1
}

printf 'Remote: %s:%s\nRepository: %s\nBranch: %s\nCommit: %s\n' \
  "$host" "$session_path" "$local_repo" "$remote_branch" "$remote_sha"
if [[ "$remote_dirty" == True ]]; then
  echo "Warning: the remote worktree has uncommitted changes; only committed Git state and the pi session will transfer." >&2
fi

git -C "$local_repo" fetch origin "$remote_branch" >/dev/null 2>&1 || true
if ! git -C "$local_repo" cat-file -e "$remote_sha^{commit}" 2>/dev/null; then
  echo "Commit is not on origin; fetching it directly from the Coder worktree..."
  git -C "$local_repo" fetch "$host:$remote_cwd" "$remote_branch"
fi
git -C "$local_repo" cat-file -e "$remote_sha^{commit}" 2>/dev/null || {
  echo "Could not fetch remote commit: $remote_sha" >&2
  exit 1
}

local_branch=${requested_branch:-$remote_branch}
if git -C "$local_repo" show-ref --verify --quiet "refs/heads/$local_branch"; then
  base="$local_branch-coder"
  local_branch=$base
  index=2
  while git -C "$local_repo" show-ref --verify --quiet "refs/heads/$local_branch"; do
    local_branch="$base-$index"
    ((index++))
  done
fi

worktree_json=$(wt -C "$local_repo" switch --create "$local_branch" \
  --base "$remote_sha" --no-cd --format=json --yes)
worktree_path=$(python3 -c 'import json,sys; print(json.load(sys.stdin)["path"])' <<<"$worktree_json")

temp_dir=$(mktemp -d "${TMPDIR:-/tmp}/pi-session.XXXXXX")
session_copy="$temp_dir/${session_id}.jsonl"
cleanup() { rm -rf "$temp_dir"; }
trap cleanup EXIT

ssh "$host" "SESSION_PATH_B64='$encoded_path' python3 -" >"$session_copy" <<'PY'
import base64
import os
import sys

path = base64.b64decode(os.environ["SESSION_PATH_B64"]).decode()
with open(path, "rb") as session:
    while chunk := session.read(1024 * 1024):
        sys.stdout.buffer.write(chunk)
PY

printf 'Worktree: %s\nLocal branch: %s\nStarting forked pi session...\n' \
  "$worktree_path" "$local_branch"
cd "$worktree_path"
pi --fork "$session_copy"
