#!/bin/sh
# delta wrapper: pick --dark/--light from macOS appearance, otherwise
# let delta use its native defaults (Monokai Extended for dark, GitHub
# for light). Keep hyperlinks for click-to-jump.

if [ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" = "Dark" ]; then
  mode=--dark
else
  mode=--light
fi

exec delta \
  "$mode" \
  --paging=never \
  --line-numbers \
  --hyperlinks \
  --hyperlinks-file-link-format="lazygit-edit://{path}:{line}" \
  "$@"
