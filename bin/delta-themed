#!/bin/sh
# delta wrapper: pick GitHub-flavored feature + --dark/--light from macOS
# appearance. Feature styles live in ~/.gitconfig ([delta "github-*"]).
# Keep hyperlinks for click-to-jump in lazygit.

if [ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" = "Dark" ]; then
  mode=--dark
  feature=github-dark
else
  mode=--light
  feature=github-light
fi

exec delta \
  "$mode" \
  --features="$feature" \
  --paging=never \
  --line-numbers \
  --hyperlinks \
  --hyperlinks-file-link-format="lazygit-edit://{path}:{line}" \
  "$@"
