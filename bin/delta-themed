#!/bin/sh
# delta wrapper: VSCode-flavored feature (matches agent TUI code render) + --dark/
# --light. Feature styles live in ~/.gitconfig ([delta "vscode-*"]). Keep
# hyperlinks for click-to-jump in lazygit.

# TEMPFIX: forced dark. Revert to macOS-appearance switch (below) once herdr
# fixes gray pane-selection color.
mode=--dark
feature=vscode-dark
# if [ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" = "Dark" ]; then
#   mode=--dark
#   feature=vscode-dark
# else
#   mode=--light
#   feature=vscode-light
# fi

exec delta \
  "$mode" \
  --features="$feature" \
  --paging=never \
  --side-by-side \
  --line-numbers \
  --hyperlinks \
  --hyperlinks-file-link-format="lazygit-edit://{path}:{line}" \
  "$@"
